# ========================================
# Configuration Django - Exemple complet
# ========================================

# DÉVELOPPEMENT
# DEBUG=True
# SECRET_KEY=dev-only-secret-key
# ALLOWED_HOSTS=localhost,127.0.0.1
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080,http://127.0.0.1:5173,http://127.0.0.1:8080
# CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# PRODUCTION (à copier dans .env.production)
# DEBUG=False
# SECRET_KEY=your-secret-key-here (générer avec: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())')
# ALLOWED_HOSTS=infosconcours.sn,www.infosconcours.sn
# CORS_ALLOWED_ORIGINS=https://infosconcours.sn,https://www.infosconcours.sn
# CSRF_TRUSTED_ORIGINS=https://infosconcours.sn,https://www.infosconcours.sn

# ========================================
# Base de données
# ========================================
DB_NAME=infos_concours
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# ========================================
# Sécurité HTTPS (production)
# ========================================
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
USE_X_FORWARDED_PROTO=True

# ========================================
# JWT Configuration
# ========================================
JWT_ACCESS_TOKEN_LIFETIME=15
JWT_REFRESH_TOKEN_LIFETIME=7

# ========================================
# Cache (optionnel, local en dev)
# ========================================
# REDIS_URL=redis://localhost:6379/0

# ========================================
# Email (optionnel pour notifications)
# ========================================
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password

# Configuration Stockage (AWS S3)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_STORAGE_BUCKET_NAME=infos-concours-files
AWS_S3_REGION=us-east-1

# Configuration Redis/Celery
REDIS_URL=redis://localhost:6379/0

# Configuration Paiements
PAYMENT_PROVIDER_MODE=mock
PAYMENT_WEBHOOK_SECRET=dev-secret

# Configuration Paydunya
PAYDUNYA_MASTER_KEY=your-paydunya-master-key
PAYDUNYA_PRIVATE_KEY=your-paydunya-private-key
PAYDUNYA_PUBLIC_KEY=your-paydunya-public-key
PAYDUNYA_TOKEN=your-paydunya-token
PAYDUNYA_MODE=test

# URLs de l'application
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Configuration Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-email-password
